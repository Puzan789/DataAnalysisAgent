# Core model and vector settings
OPENAI_KEY=
OPENAI_MODEL=
EMBEDDING_MODEL=
QDRANT_URL=http://qdrant:6333

# MongoDB
MONGO_DB_URI=mongodb://mongodb:27017
MONGO_DB_NAME=data_analysis

# PostgreSQL
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=mydb

# Vector collections
TABLE_DESCRIPTION_COLLECTION=table_descriptions
DB_SCHEMA_COLLECTION=db_schema
COMPANY_COLLECTION=companies

# Auth
AUTH_SECRET=
AUTH_TOKEN_EXP_MIN=1440

# CORS and debug
CORS_ORIGINS=http://localhost:3000
DEBUG=true

# Optional LangSmith settings
langsmith_tracing=
langsmith_endpoint=
langsmith_api_key=
langsmith_project=